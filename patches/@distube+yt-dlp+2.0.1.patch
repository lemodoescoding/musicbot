+const __DOWNLOAD_DIR = __path.join(__os.tmpdir(), "yt-dlp-downloads");
+if(!__fs.existsSync(__DOWNLOAD_DIR)) {
+    __fs.mkdirSync(__DOWNLOAD_DIR, { recursive: true });
+}
+
+/**
+ * tracks currently downloading/downloaded local file based on the ytdlp request and keyed by the original youtube video ID
+ *
+ * @type {Map<string, string>}
+ * */
+const __downloadedFiles = new Map();
+
+/**
+ * @param { Number } maxAgeMs
+ * */
+function __sweepOrphanedDownloads(maxAgeMs = 60 * 60 * 100) {
+    let entries;
+    try {
+        entries = __fs.readdirSync(__DOWNLOAD_DIR);
+    } catch {
+        return;
+    }
+
+    const tracked = new Set(__downloadedFiles.values());
+    const now = Date.now();
+
+    for(const entry of entries) {
+        const full = __path.join(__DOWNLOAD_DIR, entry);
+        if(tracked.has(full)) {
+            continue;
+        }
+
+        try {
+            const stat = __fs.statSync(full);
+            if(now - stat.mtimeMs >= maxAgeMs) {
+                console.warn(`[yt-dlp-download] deleting orphaned file ${entry}`);
+                __fs.unlinkSync(full);
+            }
+        } catch {}
+    }
+}
+
+/**
+ * @param { String } videoUrl
+ * @param { String } format
+ * @returns {Promise<string>}
+ * */
+function __downloadToLocalFile(videoUrl, format) {
+    __sweepOrphanedDownloads();
+
+    const existing = __downloadedFiles.get(videoUrl);
+    if(existing && __fs.existsSync(existing)) {
+        return Promise.resolve(`file:///${existing}`);
+    }
+
+    const filename = `${__crypto.randomUUID()}.audio`;
+    const filePath = __path.join(__DOWNLOAD_DIR, filename);
+
+    return new Promise((resolve, reject) => {
+        __execFile(
+            "yt-dlp",
+            ["-f", format, "-o", filePath, "--no-part", videoUrl],
+            { timeout: 5 * 60 * 1000 },
+            (error, _, stderr) => {
+                if(error) {
+                    console.error(
+                        `[yt-dlp-download] Download failed for ${videoUrl}:\n` +
+						`--- stderr tail ---\n${(stderr || "").slice(-4096)}\n-------------------`,
+                    );
+
+                    try {
+                        __fs.unlinkSync(filePath);
+                    } catch {}
+
+                    reject(error);
+                    return;
+                }
+
+                __downloadedFiles.set(videoUrl, filePath);
+                if(String(process.env.DISTUBE_DEBUG).toLowerCase() === "true") {
+                    console.log(`[yt-dlp-downloads] Downloaded ${videoUrl} to ${filePath}`)
+                }
+                resolve(`file://${filePath}`);
+            }
+        )
+    })
+}
+
+/**
+ * @param {String} videoUrl
+ * */
+function __cleanupDownload(videoUrl) {
+    const filePath = __downloadedFiles.get(videoUrl);
+    if(!filePath) {
+        return;
+    }
+
+    try {
+        __fs.unlinkSync(filePath)
+
+        if(String(process.env.DISTUBE_DEBUG).toLowerCase() === "true") {
+            console.log(`[yt-dlp-downloads] Deleted ${videoUrl} on path ${filePath}`);
+        }
+    } catch {}
+}
